# Copy this file to:
#   ~/Library/Application Support/messages-to-telegram/config.env
#
# Then fill in TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

WATCH_MESSAGES=1
WATCH_NOTIFICATIONS=0
WATCH_PARCELS=1
BOT_COMMANDS_ENABLED=1
# Optional comma-separated extra chat IDs allowed to control the bot.
# BOT_ALLOWED_CHAT_IDS=

# Default: ~/Library/Messages/chat.db
# MESSAGES_DB_PATH=

# Sequoia default:
#   ~/Library/Group Containers/group.com.apple.usernoted/db2/db
# Older macOS fallback is usually under:
#   $(getconf DARWIN_USER_DIR)/com.apple.notificationcenter/db2/db
# NOTIFICATION_DB_PATH=

# Default: ~/Library/Application Support/messages-to-telegram/state.json
# STATE_PATH=

# Default: ~/Library/Application Support/messages-to-telegram/app_map.json
# APP_MAP_PATH=

# Default: ~/Library/Application Support/messages-to-telegram/parcels.json
# PARCELS_PATH=

POLL_INTERVAL_SECONDS=5
PARCEL_POLL_INTERVAL_SECONDS=3600
BATCH_LIMIT=20

# 1 means only messages received from other people are forwarded.
# Set to 0 if you also want messages sent from this Mac/iPhone account.
FORWARD_INCOMING_ONLY=1

# If a message has no readable text but has attachments, forward an attachment note.
FORWARD_EMPTY_MESSAGES=0

# Optional comma-separated filters. Matching is case-insensitive substring matching.
# SENDER_ALLOWLIST=+15551234567,person@example.com
# CHAT_ALLOWLIST=Family,Project
# SERVICE_ALLOWLIST=iMessage,SMS

# Notification Center forwarding is best-effort and uses macOS private storage.
# Keep Messages bundle IDs denied here to avoid duplicate iMessage/SMS forwards
# when WATCH_MESSAGES=1 and WATCH_NOTIFICATIONS=1.
NOTIFICATION_APP_DENYLIST=com.apple.MobileSMS,com.apple.iChat,com.tdesktop.telegram,org.telegram.desktop,ru.keepcoder.Telegram
# NOTIFICATION_APP_ALLOWLIST=com.tinyspeck.slackmacgap,com.apple.mail
NOTIFICATION_PRESENTED_ONLY=0

# full: include body
# redacted: hide body but include metadata
# sender_only: include sender/chat/time only
MESSAGE_TEXT_MODE=full

# full: include notification title/subtitle/body
# redacted: hide notification body but include app/time/title
# app_only: include app/time only
NOTIFICATION_TEXT_MODE=full

DISABLE_NOTIFICATION=0
PROTECT_CONTENT=0
SEND_STARTUP_MESSAGE=1
NEWS_LANGUAGE=ko
NEWS_COUNTRY=KR
STOCK_WATCHLIST=^GSPC,^IXIC,AAPL,NVDA,005930.KS

# naver_scrape uses Naver search's public web UI/internal JSON path.
# It can break if Naver changes the page or blocks automated requests.
PARCEL_PROVIDER=naver_scrape
# Optional. Leave empty to scrape the key from Naver search when needed.
# NAVER_PARCEL_PASSPORT_KEY=
# NAVER_PARCEL_SEARCH_URL=https://search.naver.com/search.naver?query=%ED%83%9D%EB%B0%B0%EC%A1%B0%ED%9A%8C
LOG_LEVEL=INFO
